#!/usr/bin/env bash
# generate-index-page.sh
# Generates README.md for docsify from markdown files.
# Title is taken from the first `# Heading` in the file, or the filename if not found.

DOCS_DIR="${1:-.}"
# DOCS_DIR="${1:-./docs}"
OUTPUT="$DOCS_DIR/README.md"

get_title() {
  local filepath="$1"
  local heading

  heading=$(grep -m 1 '^# ' "$filepath" | sed 's/^# //')

  if [[ -n "$heading" ]]; then
    echo "$heading"
  else
    basename "$filepath" .md | sed 's/-/ /g'
  fi
}

echo "<!-- Auto-generated by generate-sidebar.sh -->" > "$OUTPUT"
echo "# ノート" >> "$OUTPUT"

find "$DOCS_DIR" -name "*.md" \
  ! -name "_*" \
  ! -name "README.md" \
  | sort \
  | while read -r filepath; do
    relpath="${filepath#$DOCS_DIR/}"
    title=$(get_title "$filepath")
    echo "- [$title]($relpath)" >> "$OUTPUT"
  done

echo "✅ $OUTPUT を生成しました"
